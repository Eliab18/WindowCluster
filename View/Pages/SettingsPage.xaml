<UserControl x:Class="FencesApp.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="ModernCircularCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Círculo exterior -->
                            <Ellipse x:Name="CheckboxCircle" 
                            Width="20" 
                            Height="20" 
                            Stroke="#DADADA" 
                            StrokeThickness="1.5"
                            Fill="Transparent"
                            Grid.Column="0"
                            Margin="0,0,10,0"/>

                            <!-- Círculo interior (visible cuando está marcado) -->
                            <Ellipse x:Name="CheckMark" 
                            Width="12" 
                            Height="12" 
                            Fill="#1ABC9C"
                            Grid.Column="0"
                            Margin="0,0,10,0"
                            Opacity="0"/>

                            <!-- Texto del CheckBox -->
                            <ContentPresenter Grid.Column="1" 
                                    VerticalAlignment="Center" 
                                    HorizontalAlignment="Left"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Cuando está marcado -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="CheckboxCircle" Property="Stroke" Value="#1ABC9C"/>
                                <Setter TargetName="CheckboxCircle" Property="Fill" Value="#1ABC9C"/>
                                <Setter TargetName="CheckMark" Property="Opacity" Value="1"/>
                                <Setter TargetName="CheckMark" Property="Fill" Value="White"/>
                            </Trigger>

                            <!-- Cuando el mouse está encima -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="CheckboxCircle" Property="Stroke" Value="#1ABC9C"/>
                            </Trigger>

                            <!-- Cuando está deshabilitado -->
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="CheckboxCircle" Property="Stroke" Value="#AAAAAA"/>
                                <Setter Property="Foreground" Value="#AAAAAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo moderno para ComboBox -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Background" Value="#F5F5F5"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DADADA"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- ToggleButton con bordes redondeados -->
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          HorizontalContentAlignment="Stretch">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Border" 
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <Grid>
                                                <ContentPresenter x:Name="ContentSite"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  Margin="4"
                                                                  Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"
                                                                  ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType={x:Type ComboBox}}}"/>
                                                <Path x:Name="Arrow"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,12,0"
                                                      Fill="#2C3E50"
                                                      Data="M 0 0 L 6 6 L 12 0 Z"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Border" Property="Background" Value="#EBEBEB"/>
                                                <Setter TargetName="Border" Property="BorderBrush" Value="#BBBBBB"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="Arrow" Property="RenderTransform">
                                                    <Setter.Value>
                                                        <RotateTransform Angle="180" CenterX="6" CenterY="3"/>
                                                    </Setter.Value>
                                                </Setter>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Foreground" Value="#AAAAAA"/>
                                                <Setter TargetName="Arrow" Property="Fill" Value="#AAAAAA"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <!-- Popup con el mismo ancho que el ComboBox y separación -->
                            <Popup x:Name="Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   VerticalOffset="5"
                                   PopupAnimation="Slide">
                                <Border x:Name="DropDownBorder"
                                        Background="White"
                                        BorderBrush="#DADADA"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        MinWidth="{Binding ActualWidth, ElementName=ToggleButton}"
                                        Padding="0,5">
                                    <ScrollViewer SnapsToDevicePixels="True" Margin="2">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para los ComboBoxItem con más espaciado -->
        <Style x:Key="ModernComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Margin" Value="2,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                Margin="{TemplateBinding Margin}"
                                CornerRadius="4">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#E0E0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el subtítulo -->
        <Style x:Key="SubtitleTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <!-- Se elimina el margen izquierdo extra para alinear a la izquierda -->
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="#ECF0F1">
        <Border Background="White" Margin="10" Padding="20">
            <!-- Alineación general a la izquierda -->
            <StackPanel HorizontalAlignment="Left">
                <!-- Título usando recurso dinámico -->
                <TextBlock Text="{DynamicResource SettingsTitle}" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Margin="0,0,0,20"
                           Foreground="#2C3E50"/>
                <!-- Reemplaza la referencia al estilo en tus CheckBoxes -->
                <CheckBox x:Name="StartWithWindowsCheckBox"
                  Content="{DynamicResource StartWithWindows}"
                  Style="{StaticResource ModernCircularCheckBoxStyle}"
                  Checked="StartWithWindowsCheckBox_Checked"
                  Unchecked="StartWithWindowsCheckBox_Unchecked"/>
                        <CheckBox x:Name="MinimizeOnCloseCheckBox"
                  Content="{DynamicResource MinimizeOnClose}"
                  Style="{StaticResource ModernCircularCheckBoxStyle}"
                  Checked="MinimizeOnCloseCheckBox_Checked"
                  Unchecked="MinimizeOnCloseCheckBox_Unchecked"/>
                <!-- Subtítulo para Idiomas, alineado a la izquierda -->
                <TextBlock Text="{DynamicResource LanguageTitle}" 
                           Style="{StaticResource SubtitleTextBlockStyle}"/>
                <!-- ComboBox para seleccionar idioma, alineado a la izquierda -->
                <ComboBox x:Name="LanguageComboBox" 
                          Style="{StaticResource ModernComboBoxStyle}" 
                          SelectionChanged="LanguageComboBox_SelectionChanged" 
                          Width="200"
                          HorizontalAlignment="Left">
                    <ComboBox.ItemContainerStyle>
                        <StaticResource ResourceKey="ModernComboBoxItemStyle"/>
                    </ComboBox.ItemContainerStyle>
                    <ComboBoxItem Content="English" Tag="en"/>
                    <ComboBoxItem Content="Español" Tag="es"/>
                </ComboBox>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>