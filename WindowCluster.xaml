<Window x:Class="FencesApp.Pages.FenceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:converters="clr-namespace:FencesApp.Converters"
        Title="FenceWindow"
        Width="Auto" Height="Auto"
        MinWidth="400" MinHeight="400"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent" 
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseLeave="Window_MouseLeave"
        AllowDrop="True" 
        Drop="Window_Drop"
        ShowInTaskbar="False"
        SizeToContent="WidthAndHeight">
    <!-- Modificar la sección de Resources en el archivo XAML -->
    <Window.Resources>

        <converters:ContrastColorConverter x:Key="ContrastColorConverter"/>


        <!-- Estilo moderno para el ContextMenu -->
        <Style x:Key="ModernContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#FF333333"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                CornerRadius="4"
                Padding="{TemplateBinding Padding}">
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo moderno para MenuItems con submenú -->
        <Style x:Key="ModernMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Grid>
                            <!-- Elemento principal -->
                            <Border x:Name="Border" Background="{TemplateBinding Background}"
                  CornerRadius="2" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter ContentSource="Header" VerticalAlignment="Center"/>
                                    <Path x:Name="Arrow" Grid.Column="1" Fill="White" Data="M 0 0 L 4 4 L 0 8 Z"
                    Visibility="Collapsed" Margin="4,0,0,0"/>
                                </Grid>
                            </Border>
                            <!-- Popup para submenú con desplazamiento -->
                            <Popup x:Name="SubMenuPopup" Placement="Right"
                 HorizontalOffset="8" VerticalOffset="0"
                 IsOpen="{TemplateBinding IsSubmenuOpen}"
                 AllowsTransparency="True" Focusable="False" PopupAnimation="Fade">
                                <Border Background="#FF333333" CornerRadius="4" Padding="4">
                                    <StackPanel IsItemsHost="True"/>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#FF555555"/>
                            </Trigger>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="Arrow" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo para el botón de hamburguesa -->
        <Style x:Key="HamburgerButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    
                        <ControlTemplate.Triggers>
                            <!--
                    <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#44FFFFFF"/>
                            </Trigger>
                                -->
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                    
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- El fence (Border principal) -->
    <Border x:Name="BackgroundPanel" CornerRadius="10" ClipToBounds="True" Background="#545e75">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header con cursor de movimiento -->
            <Border x:Name="TitleContainer" Padding="5" CornerRadius="0" MouseEnter="TitleContainer_MouseEnter"    Background="Transparent" MouseLeave="TitleContainer_MouseLeave">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

             

               
                    <!-- Botón de menú tipo hamburguesa -->
                    <Button x:Name="HamburgerButton" Grid.Column="0" 
                    Style="{StaticResource HamburgerButtonStyle}" 
                    Click="HamburgerButton_Click" Opacity="0">

                        <!-- Icono del botón -->
                        <fa:FontAwesome Icon="Bars" FontSize="16" Margin="5">
                            <fa:FontAwesome.Foreground>
                                <MultiBinding Converter="{StaticResource ContrastColorConverter}">
                                    <Binding ElementName="TitleContainer" Path="Background.Color"/>
                                    <Binding ElementName="BackgroundPanel" Path="Background.Color"/>
                                </MultiBinding>
                            </fa:FontAwesome.Foreground>
                        </fa:FontAwesome>

                        <!-- Menu del hamburger button (CORRECCIÓN: Colocado dentro del Button) -->
                        <Button.ContextMenu>
                            <ContextMenu x:Name="HamburgerMenu" Style="{StaticResource ModernContextMenuStyle}">
                                <MenuItem Header="{DynamicResource FenceWindowMenuRoot}" Click="AbrirRaiz_Click" Style="{StaticResource ModernMenuItemStyle}"/>
                                <MenuItem Header="{DynamicResource FenceWindowMenuSort}" Style="{StaticResource ModernMenuItemStyle}">
                                    <MenuItem Header="{DynamicResource FenceWindowMenuName}" Click="OrdenarPorNombre_Click" Style="{StaticResource ModernMenuItemStyle}"/>
                                    <MenuItem Header="{DynamicResource FenceWindowMenuDate}" Click="OrdenarPorFecha_Click" Style="{StaticResource ModernMenuItemStyle}"/>
                                    <MenuItem Header="{DynamicResource FenceWindowMenuType}" Click="OrdenarPorTipo_Click" Style="{StaticResource ModernMenuItemStyle}"/>
                                </MenuItem>
                                <MenuItem Header="{DynamicResource FenceWindowMenuDropFiles}" Click="SoltarArchivos_Click" Style="{StaticResource ModernMenuItemStyle}"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>

                    <!-- Título del Fence -->
                    <TextBlock x:Name="FenceTitle" Grid.Column="1"
                              Text="{DynamicResource NewFence}"
                              Foreground="White" FontSize="20" 
                              VerticalAlignment="Top" HorizontalAlignment="Center"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto"
                    HorizontalScrollBarVisibility="Disabled"
                    Margin="5">
                <!-- Modificaciones para el WrapPanel en el XAML -->
                <WrapPanel x:Name="FileContainer"
                           Orientation="Horizontal"
                           Margin="1"
                           MaxWidth="450"
                           
                           AllowDrop="True"
                           Drop="FileContainer_Drop"
                           ItemWidth="80"
                           HorizontalAlignment="Left"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>